{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Yarp": "Information"
    }
  },
  "Jwt": {
    "Secret": "your-super-secret-key-at-least-32-characters-long",
    "Issuer": "SmartEvent.Identity",
    "Audience": "SmartEvent"
  },
  "IdentityService": {
    "Url": "https://localhost:7080"
  },
  "FrontendUrl": "https://localhost:5173",
  "PublicPaths": [ "/api/auth/login", "/api/auth/register", "/api/auth/google-login", "/api/auth/google-callback" ],
  "ReverseProxy": {
    "Routes": {
      "identity-service": {
        "ClusterId": "identity-cluster",
        "Match": {
          "Path": "/api/auth/{**catch-all}"
        }
      },
      "event-service": {
        "ClusterId": "event-cluster",
        "Match": {
          "Path": "/api/events/{**catch-all}"
        }
      },
      "ticket-service": {
        "ClusterId": "ticket-cluster",
        "Match": {
          "Path": "/api/tickets/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "identity-cluster": {
        "Destinations": {
          "identity-destination": {
            "Address": "https://localhost:7080/"
          }
        }
      },
      "event-cluster": {
        "Destinations": {
          "event-destination": {
            "Address": "https://localhost:7081/"
          }
        }
      },
      "ticket-cluster": {
        "Destinations": {
          "ticket-destination": {
            "Address": "https://localhost:7082/"
          }
        }
      }
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Debug",
      "Override": {
        "Microsoft": "Information",
        "System": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "Seq",
        "Args": {
          "serverUrl": "http://localhost:5341"
        }
      }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithThreadId" ],
    "Properties": {
      "Application": "IdentityService"
    }
  }
}